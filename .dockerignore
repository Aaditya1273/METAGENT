# ── TaxFi — .dockerignore ─────────────────────────────────────────────────
# Exclude files from Docker build context to keep images small.

# Version control
.git
.gitignore
.gitattributes

# Python
__pycache__
*.pyc
*.pyo
.pytest_cache
.venv
venv

# Node
node_modules
frontend/node_modules
frontend/dist

# IDE
.idea
.vscode
*.swp
*.swo

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Documentation
README.md
idea.md
LICENSE.md

# Other
.vscode
*.log
